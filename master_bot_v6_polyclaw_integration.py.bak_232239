def _try_import(name, fromlist=None):
    try:
        if fromlist:
            m = __import__(name, fromlist=fromlist)
            return m, True
        return __import__(name), True
    except ImportError as e:
        print(f"[IMPORT] WARNING: {name} not available ({e})")
        return None, False

