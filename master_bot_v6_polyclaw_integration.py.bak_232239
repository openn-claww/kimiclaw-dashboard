#!/usr/bin/env python3
"""
master_bot_v6_polyclaw_integration.py — V6 with proxy + auto-redeem
Fixes:
  [FIX-1] Rotating proxy + CLOB health check + manual sell queue
  [FIX-2] Auto-poll positions for resolution every 5 minutes
  [FIX-3] Auto-redeem winning positions via CTF / CLOB API
  [FIX-4] Full P&L tracking logged on every redemption
  [FIX-5] Retry failed redemptions (3x backoff) + alert user
"""

# ── PID mutex ─────────────────────────────────────────────────────────────────
try:
    from bot_lock import acquire_lock
    acquire_lock()
except ImportError:
    import fcntl as _fcntl, sys as _sys, os as _os, signal as _signal
    _LOCK_FILE = '/tmp/master_bot_v6.lock'

    def _is_stale_lock(path):
        """[FIX-3] Check if lock file holds a dead PID."""
        try:
            pid = int(Path(path).read_text().strip())
            _os.kill(pid, 0)   # signal 0 = check existence only
            return False       # process exists
        except (ValueError, FileNotFoundError):
            return True        # no file or no PID
        except ProcessLookupError:
            return True        # PID doesn't exist = stale
        except PermissionError:
            return False       # process exists, we just can't signal it

    if Path(_LOCK_FILE).exists() and _is_stale_lock(_LOCK_FILE):
        _os.unlink(_LOCK_FILE)
        log.warning(f"[Lock] Removed stale lock file {_LOCK_FILE}")

    _lf = open(_LOCK_FILE, 'w')
    try:
        _fcntl.flock(_lf, _fcntl.LOCK_EX | _fcntl.LOCK_NB)
        _lf.write(str(_os.getpid()))
        _lf.flush()
    except IOError:
        pid_in_file = None
        try:
            pid_in_file = int(Path(_LOCK_FILE).read_text().strip())
        except Exception:
            pass
        print(f"FATAL: Another instance running (PID {pid_in_file}). "
              f"Delete {_LOCK_FILE} to override.")
        _sys.exit(1)

